# Copy to .env and fill in. Never commit .env.

# PostgreSQL connection string used by Prisma.
DATABASE_URL="postgresql://teamwiki:teamwiki@localhost:5433/teamwiki?schema=public"

# Auth (used in later phases; documented here so the contract is one place).
# Must be at least 32 characters. Generate with: openssl rand -hex 32
JWT_SECRET="replace-with-at-least-32-random-chars!!"
ACCESS_TOKEN_TTL="15m"

# Filesystem MCP import root (Phase 7). Imports are confined to this directory.
IMPORT_ROOT="./import-docs"
